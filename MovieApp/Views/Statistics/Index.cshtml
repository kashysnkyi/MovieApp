@{
    ViewData["Title"] = "Statistics";
}

<h2 class="mb-4">📊 Statistics</h2>

<div class="row">
    <div class="col-md-6">
        <h4>Films by Genre</h4>
        <canvas id="genreChart"></canvas>
    </div>

    <div class="col-md-6">
        <h4>Average Rating by Film</h4>
        <canvas id="ratingChart"></canvas>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const genreLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.GenreLabels));
    const genreData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.GenreCounts));

    new Chart(document.getElementById('genreChart'), {
        type: 'pie',
        data: {
            labels: genreLabels,
            datasets: [{
                data: genreData,
                backgroundColor: [
                    '#ff6384',
                    '#36a2eb',
                    '#ffce56',
                    '#4bc0c0',
                    '#9966ff'
                ]
            }]
        }
    });

    const filmLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.FilmLabels));
    const filmRatings = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.FilmRatings));

    new Chart(document.getElementById('ratingChart'), {
        type: 'bar',
        data: {
            labels: filmLabels,
            datasets: [{
                label: 'Average Rating',
                data: filmRatings,
                backgroundColor: '#ffd700'
            }]
        },
        options: {
            scales: {
                y: {
                    beginAtZero: true,
                    max: 10
                }
            }
        }
    });
</script>